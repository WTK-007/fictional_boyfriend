# ============================================================================
# 纸片人男友 - 环境变量模板
# ----------------------------------------------------------------------------
# 复制此文件为 .env.local 后填入真实值；.env.local 不要提交到 git。
# 标 [必填] 的不配应用会启动报错；[可选] 的缺省会走 fallback 或跳过对应功能。
# ============================================================================


# ---------- 数据库 (Neon Postgres) ----------
# [必填] Neon serverless 连接串，必须带 ?sslmode=require
# 控制台: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/dbname?sslmode=require


# ---------- 鉴权 / Session (BetterAuth) ----------
# [必填-生产] BetterAuth session 签名密钥，至少 32 个字符
# 生成: openssl rand -hex 32
# 缺省时按 BETTER_AUTH_SECRET → AUTH_SECRET → DATABASE_URL 依次 fallback
BETTER_AUTH_SECRET=

# [必填-生产] BetterAuth 用于拼 OAuth callback URL 的对外 baseURL
# 本地: http://localhost:3000  生产: https://paperboyfriend.space
BETTER_AUTH_URL=http://localhost:3000

# [可选] BetterAuth 客户端 (createAuthClient) 的 baseURL；同源部署可留空
# 跨域 / 子域部署时设为完整 URL (会暴露到浏览器)
NEXT_PUBLIC_BETTER_AUTH_URL=

# [兼容] 旧版 HMAC session 密钥；BetterAuth 接管后保留只作为 fallback,可空
AUTH_SECRET=


# ---------- Google OAuth (BetterAuth socialProviders) ----------
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs 必须加:
#   本地: http://localhost:3000/api/auth/callback/google
#   生产: https://paperboyfriend.space/api/auth/callback/google
# [可选] 不配则后端不启用 Google provider,前端按钮也不渲染
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [可选-前端开关] 设为 'true' 时 AuthForm 才渲染 "Google 登录" 按钮
# 配齐 GOOGLE_CLIENT_ID/SECRET + 此开关都是 true 才生效
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED=


# ---------- Cloudflare Turnstile (注册/登录人机校验) ----------
# [可选-本地 / 必填-生产] 服务端 secret key；本地缺省时校验自动跳过
# 控制台: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=

# [必填-生产] 前端 site key (NEXT_PUBLIC_ 会暴露到浏览器，只放 site key 不要放 secret)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=


# ---------- Cloudflare R2 (媒体存储) ----------
# 所有 AI 生成的音/图都存这里。5 个变量都 [必填]，缺一上传必崩。
# 控制台: https://dash.cloudflare.com/?to=/:account/r2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# 公开访问前缀 (Public Development URL 或自定义域名)，落库存的就是 ${R2_PUBLIC_URL}/...
R2_PUBLIC_URL=https://pub-xxx.r2.dev


# ---------- 字节火山 TTS (语音合成) ----------
# [必填] 火山引擎 Seed TTS API Key
# 控制台: https://console.volcengine.com/speech
VOLC_SPEECH_API_KEY=

# [可选] TTS 资源 ID，缺省走 'seed-tts-2.0'
VOLC_SPEECH_RESOURCE_ID=


# ---------- 扣子 / Coze SDK (LLM + 图像生成) ----------
# coze-coding-dev-sdk 的 new Config() 会自动从环境读取所需 token。
# 具体 key 名见 SDK 文档 (待确认)。
# COZE_API_TOKEN=
# COZE_API_BASE=


# ---------- Resend (邮件) ----------
# [必填] Resend API key；缺省时欢迎信 / 每日情话发不出去但不影响注册
# 控制台: https://resend.com/api-keys
RESEND_API_KEY=re_xxx


# ---------- Cron (每日情话群发) ----------
# [必填] /api/cron/daily-email 的 Bearer Token 校验密钥
# 调用方式: curl -H "Authorization: Bearer $CRON_SECRET" https://.../api/cron/daily-email
# 生成: openssl rand -hex 32
CRON_SECRET=


# ---------- Crisp (在线客服) ----------
# [可选] Crisp Website ID；缺省时聊天悬浮窗不加载
# 控制台: https://app.crisp.chat/website/<id>/settings/
NEXT_PUBLIC_CRISP_WEBSITE_ID=


# ---------- 扣子项目环境标识 ----------
# [可选] 设为 'DEV' 时 layout 会启用 dev-only 行为；生产环境留空或别设
COZE_PROJECT_ENV=
